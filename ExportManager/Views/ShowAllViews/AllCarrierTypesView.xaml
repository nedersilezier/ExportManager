<local:AllViewBase x:Class="ExportManager.Views.ShowAllViews.AllCarrierTypesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExportManager.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <!--<Label>All carrier types</Label>-->
        <DataGrid AutoGenerateColumns="False" ItemsSource="{Binding List, IsAsync=True}" Margin="0,0,-831,0" SelectionChanged="DataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="400"/>
                <DataGridTextColumn Header="Width" Binding="{Binding Width}" Width="75"/>
                <DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="75"/>
                <DataGridTextColumn Header="Maximum height" Binding="{Binding MaxHeight}" Width="Auto"/>
                <DataGridTextColumn Header="Area" Binding="{Binding Area}" Width="100"/>
                <DataGridTextColumn Header="Weight" Binding="{Binding Weight}" Width="75"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Remarks}" Width="550"/>
                <DataGridTextColumn Header="Last updated" Binding="{Binding UpdatedAt}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</local:AllViewBase>
