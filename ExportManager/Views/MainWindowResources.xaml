                    xmlns:vwAdd="clr-namespace:ExportManager.Views.AddViews"
                    xmlns:vwReport="clr-namespace:ExportManager.Views.ReportViews">
    <!--Converters-->
    <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    <!--Templates for menu items with children-->
    <HierarchicalDataTemplate x:Key="BasicDataTemplate" ItemsSource="{Binding Children}">
        <TextBlock Text="{Binding DisplayName}" />
    </HierarchicalDataTemplate>
    <!--Textbox content vertical alignment-->
    <Style TargetType="TextBox">
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="2,0,2,0"/>
    </Style>
    
    
