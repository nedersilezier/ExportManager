<local:NewItemViewBase x:Class="ExportManager.Views.NewCarrierTypeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExportManager.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Label Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center">Name</Label>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Path=Name, UpdateSourceTrigger=PropertyChanged}"/>
        <Label Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center">Width</Label>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Path=Width, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
        <Label Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center">Length</Label>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Path=Length, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
        <Label Grid.Row="3" Grid.Column="0" HorizontalAlignment="Center">Maximum height</Label>
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Path=MaxHeight, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
        <Label Grid.Row="4" Grid.Column="0" HorizontalAlignment="Center">Weight</Label>
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Path=Weight, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
        <Label Grid.Row="5" Grid.Column="0" HorizontalAlignment="Center">Shelf weight</Label>
        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Path=ShelfWeight, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
        <Label Grid.Row="6" Grid.Column="0" HorizontalAlignment="Center">Remarks</Label>
        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Path=Remarks, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
    </Grid>
</local:NewItemViewBase>
