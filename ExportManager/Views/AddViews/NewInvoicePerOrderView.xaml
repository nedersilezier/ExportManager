<UserControl x:Class="ExportManager.Views.AddViews.NewInvoicePerOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExportManager.Views"
             xmlns:behaviors="clr-namespace:ExportManager.Behaviors"
             xmlns:converters="clr-namespace:ExportManager.Models.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:PercentConverter x:Key="IntToPercent"/>
    </UserControl.Resources>
    <TabControl SelectedIndex="{Binding SelectedTabIndex}">
        <TabItem Header="General">
            <Grid Margin="20, 15, 20, 15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <!--Spacer-->
                    <RowDefinition Height="15"/>
                    <!--Expander-->
                    <RowDefinition Height="Auto"/>
                    <!--Spacer-->
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Margin="0,0,0,4" HorizontalAlignment="Center">Order information</Label>
                <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="5" Margin="0, 0, 10, 4" BorderBrush="LightGray" Height="1" BorderThickness="1" VerticalAlignment="Center"/>
                <Label Grid.Row="1" Grid.Column="1" Margin="0, 4, 0, 4">Client</Label>
                <TextBox Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="1" Margin="0, 4, 0, 4" Text="{Binding ClientDisplayName, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="true"/>
                <Button Grid.Row="1" Grid.Column="3" Content="Browse orders" Command="{Binding SelectOrderCommand}" Width="100" Margin="10, 4, 10, 4" HorizontalAlignment="Left"/>
                <Label Grid.Row="2" Grid.Column="1" Margin="0, 4, 0, 4" Content="Order Date:"/>
                <TextBox Grid.Row="2" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding OrderDate, StringFormat=d, Mode=OneWay}" IsReadOnly="True"/>
                <Label Grid.Row="3" Grid.Column="1" Margin="0, 4, 0, 4" Content="Delivery Date:"/>
                <TextBox Grid.Row="3" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding DeliveryDate, StringFormat=d, Mode=OneWay}" IsReadOnly="True"/>

                <Expander Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="6" HorizontalAlignment="Stretch">
                    <Expander.Header>
                        <DockPanel LastChildFill="True" HorizontalAlignment="Stretch" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Expander}}">
                            <TextBlock Text="Client details" Margin="0, 4, 0, 4" VerticalAlignment="Center"/>
                            <Border Margin="60, 0, 10, 4" BorderBrush="LightGray" Height="1" BorderThickness="1" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Expander.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Row="1" Grid.Column="1" Margin="0, 4, 0, 4">Name</Label>
                        <TextBox Grid.Row="1" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding Client.Name, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="true"/>
                        <Label Grid.Row="2" Grid.Column="1" Margin="0, 4, 0, 4">Tax ID</Label>
                        <TextBox Grid.Row="2" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding Client.TaxId, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="true"/>
                        <Label Grid.Row="3" Grid.Column="1" Margin="0, 4, 0, 4">Street</Label>
                        <TextBox Grid.Row="3" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding Client.Street, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="true"/>
                        <Label Grid.Row="4" Grid.Column="1" Margin="0, 4, 0, 4">House number</Label>
                        <TextBox Grid.Row="4" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding Client.FullHouseNumber, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="true"/>
                        <Label Grid.Row="5" Grid.Column="1" Margin="0, 4, 0, 4">City</Label>
                        <TextBox Grid.Row="5" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding Client.City, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="true"/>
                        <Label Grid.Row="6" Grid.Column="1" Margin="0, 4, 0, 4">Postal code</Label>
                        <TextBox Grid.Row="6" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding Client.PostalCode, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="true"/>
                        <Label Grid.Row="7" Grid.Column="1" Margin="0, 4, 0, 4">Country</Label>
                        <TextBox Grid.Row="7" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding Client.Country, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="true"/>
                    </Grid>
                </Expander>

                <Label Grid.Row="7" Grid.Column="0" Margin="0, 0, 0, 4" HorizontalAlignment="Center">Invoice information</Label>
                <Border Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="5" Margin="0, 0, 10, 4" BorderBrush="LightGray" Height="1" BorderThickness="1" VerticalAlignment="Center"/>
                <Label Grid.Row="8" Grid.Column="1" Margin="0, 4, 0, 4" Content="Invoice number:"/>
                <TextBox Grid.Row="8" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding InvoiceNo, Mode=OneWay}" IsReadOnly="True"/>
                <Label Grid.Row="9" Grid.Column="1" Margin="0, 4, 0, 4" Content="Invoice date:"/>
                <TextBox Grid.Row="9" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding InvoiceDate, StringFormat=d, Mode=OneWay}" IsReadOnly="True"/>
                <Label Grid.Row="10" Grid.Column="1" Margin="0, 4, 0, 4" Content="Payment date:"/>
                <DatePicker Grid.Row="10" Grid.Column="2" Margin="0, 4, 0, 4" SelectedDate="{Binding PaymentDate, Mode=TwoWay}" VerticalContentAlignment="Center"/>
                <Label Grid.Row="11" Grid.Column="1" Margin="0, 4, 0, 4" Content="Payment method:"/>
                <ComboBox Grid.Row="11" Grid.Column="2" Margin="0, 4, 0, 4" ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding SelectedPaymentMethod}" VerticalContentAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Value}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Label Grid.Row="12" Grid.Column="1" Margin="0, 4, 0, 4" Content="Invoice status:"/>
                <TextBox Grid.Row="12" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding Status, Mode=OneWay}" IsReadOnly="True"/>
                <Label Grid.Row="13" Grid.Column="1" Margin="0, 4, 0, 4" Content="Remarks:"/>
                <TextBox Grid.Row="13" Grid.Column="2" Grid.ColumnSpan="1" Margin="0, 2, 0, 2"
                        Text="{Binding Path=Remarks, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                        VerticalContentAlignment="Top"
                        VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </TabItem>
        <TabItem Header="Finances">
            <Grid Margin="20, 15, 20, 15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Margin="0, 0, 0, 10" HorizontalAlignment="Center">Invoice summary</Label>
                <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="5" Margin="0, 0, 10, 4" BorderBrush="LightGray" Height="1" BorderThickness="1" VerticalAlignment="Center"/>
                <Label Grid.Row="1" Grid.Column="1" Margin="0, 4, 0, 4">Net total:</Label>
                <TextBox Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="1" Margin="0, 4, 0, 4" Text="{Binding NetAmount, StringFormat=N2, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="true"/>
                <Label Grid.Row="2" Grid.Column="1" Margin="0, 4, 0, 4" Content="Tax rate:"/>
                <TextBox x:Name="TaxRateBox" Grid.Row="2" Grid.Column="2" Margin="0, 4, 0, 4" 
                         Text="{Binding TaxRate, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource IntToPercent}}" 
                         behaviors:PercentageTextBoxBehavior.IsPercentage="True"
                         MaxLength="4"/>
                <TextBlock Grid.Row="2" Grid.Column="3" Margin="0, 4, 0, 4" VerticalAlignment="Center" Foreground="Red">
                    <TextBlock.Text>
                        <Binding ElementName="TaxRateBox" Path="(Validation.Errors)[0].ErrorContent"/>
                    </TextBlock.Text>
                </TextBlock>
                <Label Grid.Row="3" Grid.Column="1" Margin="0, 4, 0, 4" Content="Tax total:"/>
                <TextBox Grid.Row="3" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding TaxAmount, StringFormat=N2, Mode=OneWay}" IsReadOnly="True"/>
                <Border Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="5" Margin="0, 0, 10, 4" BorderBrush="LightGray" Height="1" BorderThickness="1" VerticalAlignment="Center"/>
                <Label Grid.Row="5" Grid.Column="1" Margin="0, 4, 0, 4" Content="Gross total:"/>
                <TextBox Grid.Row="5" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding GrossAmount, StringFormat=N2, Mode=OneWay}" IsReadOnly="True"/>
                <Label Grid.Row="6" Grid.Column="1" Margin="0, 4, 0, 4" Content="Storage cost:"/>
                <TextBox Grid.Row="6" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding StorageCost, StringFormat=N2, Mode=TwoWay}"/>
                <Label Grid.Row="7" Grid.Column="1" Margin="0, 4, 0, 4" Content="Transport cost:"/>
                <TextBox Grid.Row="7" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding TransportCost, StringFormat=N2, Mode=TwoWay}"/>
            </Grid>
        </TabItem>
        <TabItem Header="Invoice items">
            <Grid>
            <DataGrid AutoGenerateColumns="False" Margin="20, 15, 20, 15" ItemsSource="{Binding OrderItemsList, Mode=TwoWay}" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Item No" Binding="{Binding ItemNo}" Width="80"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                    <DataGridTextColumn Header="Unit price" Binding="{Binding UnitPrice, StringFormat=N2}" Width="100"/>
                    <DataGridTextColumn Header="Discount" Binding="{Binding Discount, StringFormat=N2, Converter={StaticResource IntToPercent}}" Width="100"/>
                    <DataGridTextColumn Header="Net amount" Binding="{Binding NetAmount, StringFormat=N2}" Width="100"/>
                    <DataGridTextColumn Header="Tax amount" Binding="{Binding TaxAmount, StringFormat=N2}" Width="100"/>
                    <DataGridTextColumn Header="Gross amount" Binding="{Binding GrossAmount, StringFormat=N2}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
