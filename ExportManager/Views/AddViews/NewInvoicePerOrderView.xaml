<UserControl x:Class="ExportManager.Views.AddViews.NewInvoicePerOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExportManager.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20, 10, 20, 10">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>
        <Label Grid.Row="0" Grid.Column="0" Margin="0, 2, 0, 10" HorizontalAlignment="Center">Order information</Label>
        <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="5" Margin="0, 0, 10, 4" BorderBrush="LightGray" Height="1" BorderThickness="1" VerticalAlignment="Center"/>
        <Label Grid.Row="1" Grid.Column="1" Margin="0, 4, 0, 4">Client</Label>
        <TextBox Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Margin="0, 4, 0, 4" Text="{Binding ClientDisplayName, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="true"/>
        <Button Grid.Row="1" Grid.Column="4" Content="Browse orders" Command="{Binding SelectOrderCommand}" Width="100" Margin="10, 4, 10, 4" HorizontalAlignment="Left"/>
        <Label Grid.Row="2" Grid.Column="1" Margin="0, 4, 0, 4" Content="Order Date:"/>
        <TextBox Grid.Row="2" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding OrderDate, StringFormat=d, Mode=OneWay}" IsReadOnly="True"/>
        <Label Grid.Row="3" Grid.Column="1" Margin="0, 4, 0, 4" Content="Delivery Date:"/>
        <TextBox Grid.Row="3" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding OrderDate, StringFormat=d, Mode=OneWay}" IsReadOnly="True"/>
        <Label Grid.Row="5" Grid.Column="0" Margin="0, 0, 0, 4" HorizontalAlignment="Center">Invoice information</Label>
        <Border Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="5" Margin="0, 0, 10, 4" BorderBrush="LightGray" Height="1" BorderThickness="1" VerticalAlignment="Center"/>
        <Label Grid.Row="6" Grid.Column="1" Margin="0, 4, 0, 4" Content="Invoice number:"/>
        <TextBox Grid.Row="6" Grid.Column="2" Margin="0, 4, 0, 4" Text="{Binding InvoiceNo, Mode=OneWay}" IsReadOnly="True"/>
    </Grid>
</UserControl>
