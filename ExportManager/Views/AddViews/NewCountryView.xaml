<local:NewItemViewBase x:Class="ExportManager.Views.AddViews.NewCountryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExportManager.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Label Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Margin="0, 8, 0, 8">Name</Label>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Path=Name, UpdateSourceTrigger=PropertyChanged}" Margin="0, 8, 0, 8"/>
        <Label Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" Margin="0, 8, 0, 8">ISO2 Code</Label>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Path=ISO2Code, UpdateSourceTrigger=PropertyChanged}" Margin="0, 8, 0, 8"/>
        <Label Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center" Margin="0, 8, 0, 8">Phone code</Label>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Path=PhoneCode, UpdateSourceTrigger=PropertyChanged}" Margin="0, 8, 0, 8"/>
        <Label Grid.Row="3" Grid.Column="0" HorizontalAlignment="Center" Margin="0, 8, 0, 8">Continent</Label>
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Path=Continent, UpdateSourceTrigger=PropertyChanged}" Margin="0, 8, 0, 8"/>
        <Label Grid.Row="4" Grid.Column="0" HorizontalAlignment="Center" Margin="0, 8, 0, 8">Member of EU</Label>
        <CheckBox Grid.Row="4" Grid.Column="1" IsChecked="{Binding IsEUMember}" Margin="0, 8, 0, 8"/>
        <Label Grid.Row="5" Grid.Column="0" HorizontalAlignment="Center" Margin="0, 8, 0, 8">Remarks</Label>
        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Path=Remarks}" AcceptsReturn="False" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0, 8, 0, 8"/>
    </Grid>
</local:NewItemViewBase>
