<local:NewItemViewBase x:Class="ExportManager.Views.AddViews.NewOrderItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExportManager.Views"
             xmlns:behaviors="clr-namespace:ExportManager.Behaviors"
             xmlns:sysglb="clr-namespace:System.Globalization;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="2, 0, 2, 0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>
        <Label Grid.Row="0" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Order</Label>
        <TextBox Grid.Row="0" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding FullDisplayName, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
IsReadOnly="True"/>
        <Label Grid.Row="1" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Select stock item</Label>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding SelectedStockItem.Value, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"/>
        <Button Grid.Row="1" Grid.Column="2" Content="Browse items" Command="{Binding SelectStockItemCommand}" Width="Auto" Margin="10, 0, 10, 0"/>
        <Label Grid.Row="2" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Grower</Label>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding GrowerDisplayName, UpdateSourceTrigger=PropertyChanged}"
IsReadOnly="True"/>
        <Label Grid.Row="3" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Cost price</Label>
        <TextBox Grid.Row="3" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding CostPrice, UpdateSourceTrigger=PropertyChanged}"
IsReadOnly="True"/>
        <Label Grid.Row="4" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Quantity</Label>
        <TextBox Grid.Row="4" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" MaxLength="7" behaviors:NumericTextBoxBehavior.IsPositiveInteger="True"/>
        <Label Grid.Row="5" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Unit price</Label>
        <!--<TextBox Grid.Row="5" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding UnitPrice, UpdateSourceTrigger=LostFocus, StringFormat='#.00', ConverterCulture={x:Static sysglb:CultureInfo.CurrentCulture}}" MaxLength="10"/>-->
        <TextBox x:Name="UnitPriceBox" Grid.Row="5" Grid.Column="1" Margin="0, 2, 0, 2">
            <TextBox.Text>
                <Binding Path="UnitPrice"
                 UpdateSourceTrigger="LostFocus">
                    <Binding.ValidationRules>
                        <behaviors:MoneyValidationRule ValidationStep="RawProposedValue"/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>
        <TextBlock Grid.Row="5" Grid.Column="2" Margin="5, 0, 0, 0" VerticalAlignment="Center" Foreground="Red">
            <TextBlock.Text>
                <Binding ElementName="UnitPriceBox" Path="(Validation.Errors)[0].ErrorContent"/>
            </TextBlock.Text>
        </TextBlock>
        <Label Grid.Row="6" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Storage cost</Label>
        <!--<TextBox Grid.Row="6" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding StorageCost, UpdateSourceTrigger=LostFocus, StringFormat='#.00', ConverterCulture={x:Static sysglb:CultureInfo.CurrentCulture}}" MaxLength="10"/>-->
        <TextBox x:Name="StorageCostBox" Grid.Row="6" Grid.Column="1" Margin="0, 2, 0, 2">
            <TextBox.Text>
                <Binding Path="StorageCost"
         UpdateSourceTrigger="LostFocus">
                    <Binding.ValidationRules>
                        <behaviors:MoneyValidationRule ValidationStep="RawProposedValue"/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>
        <TextBlock Grid.Row="6" Grid.Column="2" Margin="5, 0, 0, 0" VerticalAlignment="Center" Foreground="Red">
            <TextBlock.Text>
                <Binding ElementName="StorageCostBox" Path="(Validation.Errors)[0].ErrorContent"/>
            </TextBlock.Text>
        </TextBlock>
        <Label Grid.Row="7" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Transport cost</Label>
        <!--<TextBox Grid.Row="7" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding TransportCost, UpdateSourceTrigger=LostFocus, StringFormat='#.00', ConverterCulture={x:Static sysglb:CultureInfo.CurrentCulture}}" MaxLength="10"/>-->
        <TextBox x:Name="TransportCostBox" Grid.Row="7" Grid.Column="1" Margin="0, 2, 0, 2">
            <TextBox.Text>
                <Binding Path="TransportCost"
         UpdateSourceTrigger="LostFocus">
                    <Binding.ValidationRules>
                        <behaviors:MoneyValidationRule ValidationStep="RawProposedValue"/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>
        <TextBlock Grid.Row="7" Grid.Column="2" Margin="5, 0, 0, 0" VerticalAlignment="Center" Foreground="Red">
            <TextBlock.Text>
                <Binding ElementName="TransportCostBox" Path="(Validation.Errors)[0].ErrorContent"/>
            </TextBlock.Text>
        </TextBlock>
        <Label Grid.Row="8" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Discount[%]</Label>
        <!--<TextBox Grid.Row="8" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding Discount, UpdateSourceTrigger=LostFocus}" MaxLength="3"/>-->
        <TextBox x:Name="DiscountBox" Grid.Row="8" Grid.Column="1" Margin="0, 2, 0, 2">
            <TextBox.Text>
                <Binding Path="Discount"
         UpdateSourceTrigger="LostFocus">
                    <Binding.ValidationRules>
                        <behaviors:DiscountValidationRule ValidationStep="RawProposedValue"/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>
        <TextBlock Grid.Row="8" Grid.Column="2" Margin="5, 0, 0, 0" VerticalAlignment="Center" Foreground="Red">
            <TextBlock.Text>
                <Binding ElementName="DiscountBox" Path="(Validation.Errors)[0].ErrorContent"/>
            </TextBlock.Text>
        </TextBlock>
        <Label Grid.Row="9" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Remarks</Label>
        <TextBox Grid.Row="9" Grid.Column="1" Margin="0, 2, 0, 2"
             Text="{Binding Path=Remarks, UpdateSourceTrigger=PropertyChanged}"
             TextWrapping="Wrap"
             VerticalContentAlignment="Top"
             VerticalScrollBarVisibility="Auto"/>
    </Grid>
</local:NewItemViewBase>
