<local:NewItemViewBase x:Class="ExportManager.Views.NewProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExportManager.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="2, 0, 2, 0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Label Grid.Row="0" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Name</Label>
        <TextBox Grid.Row="0" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding Path=Name, UpdateSourceTrigger=PropertyChanged}"/>
        <Label Grid.Row="1" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Pot size</Label>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding Path=Potsize, UpdateSourceTrigger=PropertyChanged}"/>
        <Label Grid.Row="2" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Height</Label>
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding Path=Height, UpdateSourceTrigger=PropertyChanged}"/>
        <Label Grid.Row="3" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Weight</Label>
        <TextBox Grid.Row="3" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding Path=Weight, UpdateSourceTrigger=LostFocus}"/>
        <Label Grid.Row="4" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Protected by CITES</Label>
        <CheckBox Grid.Row="4" Grid.Column="1" Margin="0, 2, 0, 2" IsChecked="{Binding Cites}" VerticalAlignment="Center"/>
        <Label Grid.Row="5" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Category</Label>
        <ComboBox Grid.Row="5" Grid.Column="1" Margin="0, 2, 0, 2" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Value}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <Button Grid.Row="5" Grid.Column="2" Margin="0, 2, 0, 2" Content="New" Command="{Binding NewCategoryCommand}"/>
        <Label Grid.Row="6" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Color</Label>
        <ComboBox Grid.Row="6" Grid.Column="1" Margin="0, 2, 0, 2" ItemsSource="{Binding Colors}" SelectedItem="{Binding SelectedColor}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Value}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <Button Grid.Row="6" Grid.Column="2" Margin="0, 2, 0, 2" Content="New" Command="{Binding NewColorCommand}"/>
        <Label Grid.Row="7" Grid.Column="0" Margin="0, 2, 0, 2" HorizontalAlignment="Center">Description</Label>
        <TextBox Grid.Row="7" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding Path=Remarks, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
    </Grid>
</local:NewItemViewBase>
