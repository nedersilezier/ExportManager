<Window x:Class="ExportManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"  
        Title="ExportManager" Height="300" Width="300" WindowState="Maximized"
        xmlns:vm="clr-namespace:ExportManager.Views"
        xmlns:msbehaviors="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:ExportManager.Behaviors"
        >
    <Window.Resources>
        <ResourceDictionary Source="MainWindowResources.xaml"  />
    </Window.Resources>
    <msbehaviors:Interaction.Behaviors>
        <behaviors:ClosingBehavior ClosingCommand="{Binding ClosingCommand}" />
    </msbehaviors:Interaction.Behaviors>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <!--Menu on the top-->
        <Menu Grid.Row="0" Margin="2, 0, 2, 0" Padding="0, 6, 0, 4">
            <MenuItem Header="_File">
                <MenuItem Header="_Exit"
                          Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="_Database">
                <MenuItem Header="_Basic data"
                          ItemsSource="{Binding DatabaseDictionaryCommands}"
                          ItemTemplate="{StaticResource BasicDataTemplate}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Command" Value="{Binding Command}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <MenuItem Header="Manage addresses"
                    Command="{Binding AddressCommand.Command}"/>
                <MenuItem Header="_Manage entities"
                    ItemsSource="{Binding EntityCommands}"
                    ItemTemplate="{StaticResource BasicDataTemplate}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Command" Value="{Binding Command}"/>
                            <Setter Property="ItemsSource" Value="{Binding Children}"/>
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Finances"/>
            <MenuItem Header="_Reports" ItemsSource="{Binding ReportCommands}" ItemTemplate="{StaticResource BasicDataTemplate}">
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem">
                        <Setter Property="Command" Value="{Binding Command}"/>
                        <Setter Property="ItemsSource" Value="{Binding Children}"/>
                    </Style>
                </MenuItem.ItemContainerStyle>
            </MenuItem>
        </Menu>
        <!--Main menu buttons-->
        <ItemsControl ItemsSource="{Binding GlobalCommands}" Grid.Row="1" Grid.ColumnSpan="2" Margin="0, 4, 0, 0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Margin="4, 0, 0, 0"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding Command}"
                    Content="{Binding DisplayName}"
                    Padding="0,0"
                    Margin="0, 0, 0, 0"
                    Style="{StaticResource CustomButtonStyle}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <!--Header, workspace, progressbar-->
        <Grid Grid.Row="2">
            <Border>
                <HeaderedContentControl Grid.Row="2" 
                                        Header="Work Area"
                                        Content="{Binding Workspaces}"
                                        ContentTemplate="{StaticResource WorkspacesTemplate}"
                                        Style="{StaticResource MainHCCStyle}"/>
            </Border>
            <!--<Border Background="#80000000" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <ProgressBar IsIndeterminate="True" Width="240" Height="14"/>
            </Border>-->
        </Grid>
        <!--Status bar-->
        <StatusBar Grid.Row="3" Grid.ColumnSpan="2" Margin="10, 0, 0, 0">
            <StatusBarItem>
                <TextBlock>Your company name</TextBlock>
            </StatusBarItem>
            <!--<Separator/>-->
            <StatusBarItem HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="14" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
