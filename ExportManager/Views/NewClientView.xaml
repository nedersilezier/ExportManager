<local:NewItemViewBase x:Class="ExportManager.Views.NewClientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExportManager.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <TabControl>
        <TabItem Header="General">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Content="Client name" HorizontalAlignment="Center" Margin="0, 2, 0, 2"/>
                <TextBox Grid.Row="0" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Grid.Row="1" Grid.Column="0" Content="Client code" HorizontalAlignment="Center" Margin="0, 2, 0, 2"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding ClientCode, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Grid.Row="2" Grid.Column="0" Content="Tax ID" HorizontalAlignment="Center" Margin="0, 2, 0, 2"/>
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding TaxId, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Grid.Row="3" Grid.Column="0" Content="Registration number" HorizontalAlignment="Center" Margin="0, 2, 0, 2"/>
                <TextBox Grid.Row="3" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding RegistrationNo, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Grid.Row="4" Grid.Column="0" Content="Remarks" HorizontalAlignment="Center" Margin="0, 2, 0, 2"/>
                <TextBox Grid.Row="4" Grid.Column="1" Margin="0, 2, 0, 2" Text="{Binding Remarks, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </TabItem>
        <TabItem Header="Address" Height="20" VerticalAlignment="Bottom">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <RadioButton Grid.Row="0" Grid.Column="0" Content="Manual address input" x:Name="ManualInput" GroupName="AddressInputType" IsChecked="{Binding IsNotAddressesNeeded}" Margin="0, 2, 0, 2" Height="20"/>
                <Label Grid.Row="1" Grid.Column="0" Content="Street" HorizontalAlignment="Center" Margin="0, 2, 0, 2"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Street, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsChecked, ElementName=ManualInput}" Margin="0, 2, 0, 2"/>
                <Label Grid.Row="2" Grid.Column="0" Content="House number" HorizontalAlignment="Center" Margin="0, 2, 0, 2"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding HouseNumber, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsChecked, ElementName=ManualInput}" Margin="0, 2, 0, 2"/>
                <Label Grid.Row="3" Grid.Column="0" Content="Apartment number" HorizontalAlignment="Center" Margin="0, 2, 0, 2"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ApartmentNumber, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsChecked, ElementName=ManualInput}" Margin="0, 2, 0, 2"/>
                <Label Grid.Row="4" Grid.Column="0" Content="City" HorizontalAlignment="Center" Margin="0, 2, 0, 2"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding City, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsChecked, ElementName=ManualInput}" Margin="0, 2, 0, 2"/>
                <Label Grid.Row="5" Grid.Column="0" Content="Zip code" HorizontalAlignment="Center" Margin="0, 2, 0, 2"/>
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding ZipCode, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsChecked, ElementName=ManualInput}" Margin="0, 2, 0, 2"/>
                <Label Grid.Row="6" Grid.Column="0" Content="Country" HorizontalAlignment="Center" Margin="0, 2, 0, 2"/>
                <ComboBox Grid.Row="6" Grid.Column="1" ItemsSource="{Binding Countries}" 
                          SelectedItem="{Binding SelectedCountry}" 
                          IsEnabled="{Binding IsChecked, ElementName=ManualInput}"
                          Margin="0, 2, 0, 2">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}">
                                <TextBlock.ToolTip>
                                    <ToolTip Content="{Binding Remarks}"/>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Row="6" Grid.Column="2" Content="Add" Command="{Binding NewCountryCommand}" IsEnabled="{Binding IsChecked, ElementName=ManualInput}" Margin="0, 2, 0, 2"/>
                <RadioButton Grid.Row="7" Grid.Column="0" Content="Use existing address" x:Name="ExistingInput" GroupName="AddressInputType" IsChecked="{Binding IsAddressesNeeded}" Margin="0, 2, 0, 2"/>
                <ComboBox Grid.Row="8" Grid.Column="1" ItemsSource="{Binding Addresses}" 
                          SelectedItem="{Binding SelectedAddress}" 
                          IsEnabled="{Binding IsChecked, ElementName=ExistingInput}"
                          Margin="0, 2, 0, 2">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FullAddress}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
        </TabItem>
        <TabItem Header="Contact">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Content="Contact person" Margin="0, 2, 0, 2" HorizontalContentAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ContactPerson, UpdateSourceTrigger=PropertyChanged}" Margin="0, 2, 0, 2"/>
                <Label Grid.Row="1" Grid.Column="0" Content="Phone number" Margin="0, 2, 0, 2" HorizontalContentAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0, 2, 0, 2"/>
                <Label Grid.Row="2" Grid.Column="0" Content="E-mail address" Margin="0, 2, 0, 2" HorizontalContentAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0, 2, 0, 2"/>
            </Grid>
        </TabItem>
    </TabControl>
</local:NewItemViewBase>
