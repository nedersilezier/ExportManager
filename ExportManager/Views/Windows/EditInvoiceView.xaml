<Window x:Class="ExportManager.Views.Windows.EditInvoiceView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExportManager.Views.Windows"
        xmlns:converters="clr-namespace:ExportManager.Models.Converters"
        mc:Ignorable="d"
        Title="{Binding DisplayName}" 
        Height="400"
        MinHeight="400" MinWidth="1000">
    <Window.Resources>
        <converters:PercentConverter x:Key="IntToPercent"/>
    </Window.Resources>
    <Grid Margin="10">
        <TabControl SelectedIndex="{Binding SelectedIndexTab}">
            <TabItem Header="Invoice Information">
                <Grid Margin="20, 20, 20, 20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Invoice No:" VerticalAlignment="Center" Margin="0, 4, 0, 4"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Invoice.InvoiceNo}" IsReadOnly="True" Margin="0, 4, 0, 4"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="Invoice Date:" VerticalAlignment="Center" Margin="0, 4, 0, 4"/>
                    <DatePicker Grid.Row="1" Grid.Column="1" SelectedDate="{Binding Invoice.InvoiceDate}" IsEnabled="False" Margin="0, 4, 0, 4"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="Payment Date:" VerticalAlignment="Center" Margin="0, 4, 0, 4"/>
                    <DatePicker Grid.Row="2" Grid.Column="1" SelectedDate="{Binding Invoice.PaymentDate}" Margin="0, 4, 0, 4" VerticalContentAlignment="Center"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="Payment Method:" VerticalAlignment="Center" Margin="0, 4, 0, 4"/>
                    <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding SelectedPaymentMethod}" VerticalContentAlignment="Center" Margin="0, 4, 0, 4">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Value}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Border Grid.Column="2" Grid.Row="0" Grid.RowSpan="5" BorderBrush="LightGray" BorderThickness="1" Margin="100, 0, 40, 10"/>
                    <!--Totals-->
                    <StackPanel Grid.Row="0" Grid.Column="3" Grid.RowSpan="5" Orientation="Vertical" Margin="0, 4, 0, 4">
                        <TextBlock Text="{Binding Invoice.TotalNet, StringFormat='Total Net: {0:N2}'}" Margin="0, 4, 0, 4"/>
                        <TextBlock Text="{Binding Invoice.TotalTax, StringFormat='Total Tax: {0:N2}'}" Margin="0, 4, 0, 4"/>
                        <TextBlock Text="{Binding Invoice.TotalGross, StringFormat='Total Gross: {0:N2}'}" Margin="0, 4, 0, 4"/>
                        <TextBlock Text="{Binding Invoice.TotalTransportCost, StringFormat='Transport Cost: {0:N2}'}" Margin="0, 4, 0, 4"/>
                        <TextBlock Text="{Binding Invoice.TotalStorageCost, StringFormat='Storage Cost: {0:N2}'}" Margin="0, 4, 0, 4"/>
                        <TextBlock Text="{Binding Invoice.TotalAmount, StringFormat='Total Amount: {0:N2}'}" Margin="0, 4, 0, 4"/>
                        <TextBlock Text="{Binding Invoice.Status, StringFormat='Status: {0}'}" Margin="0, 4, 0, 4"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Client Details">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="20, 20, 20, 20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="400"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Client Name:" VerticalAlignment="Center" Margin="0, 4, 0, 4"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Buyer.Name, Mode=TwoWay}" Margin="0, 4, 0, 4"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Tax ID:" VerticalAlignment="Center" Margin="0, 4, 0, 4"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Buyer.TaxId, Mode=TwoWay}" Margin="0, 4, 0, 4"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Street:" VerticalAlignment="Center" Margin="0, 4, 0, 4"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Buyer.Street, Mode=TwoWay}" Margin="0, 4, 0, 4"/>

                        <Label Grid.Row="3" Grid.Column="0" Content="House No:" VerticalAlignment="Center" Margin="0, 4, 0, 4"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Buyer.FullHouseNo, Mode=TwoWay}" Margin="0, 4, 0, 4"/>

                        <Label Grid.Row="4" Grid.Column="0" Content="City:" VerticalAlignment="Center" Margin="0, 4, 0, 4"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Buyer.City, Mode=TwoWay}" Margin="0, 4, 0, 4"/>

                        <Label Grid.Row="5" Grid.Column="0" Content="Postal Code:" VerticalAlignment="Center" Margin="0, 4, 0, 4"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Buyer.PostalCode, Mode=TwoWay}" Margin="0, 4, 0, 4"/>

                        <Label Grid.Row="6" Grid.Column="0" Content="Country:" VerticalAlignment="Center" Margin="0, 4, 0, 4"/>
                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Buyer.Country, Mode=TwoWay}" Margin="0, 4, 0, 4"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Invoice Items">
                <DataGrid ItemsSource="{Binding InvoiceItems}" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="False" 
                  Margin="20, 20, 20, 20"
                  VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Item No" Binding="{Binding ItemNo}" Width="60"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding FullName}" MinWidth="250" Width="*"/>
                        <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity, Mode=TwoWay}" Width="80"/>
                        <DataGridTextColumn Header="Unit price" Binding="{Binding UnitPriceSnapshot, Mode=TwoWay, StringFormat=N2}" Width="80"/>
                        <DataGridTextColumn Header="Tax rate" Binding="{Binding TaxRateSnapshot, Mode=TwoWay, StringFormat=N2, Converter={StaticResource IntToPercent}}" Width="80"/>
                        <DataGridTextColumn Header="Net amount" Binding="{Binding NetAmount, StringFormat=N2}" IsReadOnly="True" Width="100"/>
                        <DataGridTextColumn Header="Tax amount" Binding="{Binding TaxAmount, StringFormat=N2}" IsReadOnly="True" Width="100"/>
                        <DataGridTextColumn Header="Gross amount" Binding="{Binding GrossAmount, StringFormat=N2}" IsReadOnly="True" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
