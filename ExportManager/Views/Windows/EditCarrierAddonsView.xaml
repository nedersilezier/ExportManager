<Window x:Class="ExportManager.Views.Windows.EditCarrierAddonsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExportManager.Views.Windows"
        xmlns:msbehaviors="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:ExportManager.Behaviors"
        mc:Ignorable="d"
SizeToContent="Height"
Background="LightGray"
BorderBrush="DarkGray"
BorderThickness="1"
ResizeMode="NoResize"
Topmost="True"
WindowStartupLocation="CenterScreen"
        Title="{Binding DisplayName}" Height="150" Width="200">
    <msbehaviors:Interaction.Triggers>
        <msbehaviors:DataTrigger Binding="{Binding IsClosing}" Value="True">
            <msbehaviors:CallMethodAction TargetObject="{Binding RelativeSource={RelativeSource AncestorType=Window}}" MethodName="Close" />
        </msbehaviors:DataTrigger>
    </msbehaviors:Interaction.Triggers>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Text="Shelves:"/>
        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" 
     Text="{Binding AmountOfShelves, UpdateSourceTrigger=PropertyChanged}"
     MaxLength="3" behaviors:NumericTextBoxBehavior.IsPositiveInteger="True"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Text="Extensions:"/>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" 
             Text="{Binding AmountOfExtensions, UpdateSourceTrigger=PropertyChanged}"
             MaxLength="3" behaviors:NumericTextBoxBehavior.IsPositiveInteger="True"/>

        <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
            Content="Save and close" Height="30" Width="100" HorizontalAlignment="Center"
            Command="{Binding EditCarrierCommand}"/>
    </Grid>
</Window>
