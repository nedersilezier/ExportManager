<Window x:Class="ExportManager.Views.Windows.NewOrderItemCarrierView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExportManager.Views.Windows"
        xmlns:behaviors="clr-namespace:ExportManager.Behaviors"
        xmlns:msbehaviors="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        Width="400"
        SizeToContent="Height"
        Background="LightGray"
        BorderBrush="DarkGray"
        BorderThickness="1"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Title="{Binding DisplayName}">
    <msbehaviors:Interaction.Triggers>
        <msbehaviors:DataTrigger Binding="{Binding IsClosing}" Value="True">
            <msbehaviors:CallMethodAction TargetObject="{Binding RelativeSource={RelativeSource AncestorType=Window}}" MethodName="Close" />
        </msbehaviors:DataTrigger>
    </msbehaviors:Interaction.Triggers>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Text="Carrier type:"/>
        <ComboBox Grid.Row="0" Grid.Column="1" Margin="0, 0, 0, 10" ItemsSource="{Binding CarrierTypes}" SelectedItem="{Binding SelectedCarrierType}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Value}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Text="Quantity:"/>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" 
                 Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                 MaxLength="4" behaviors:NumericTextBoxBehavior.IsPositiveInteger="True"/>

        <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
                Content="Add carrier" Height="30" Width="100" HorizontalAlignment="Center"
                Command="{Binding AddCarrierCommand}"/>
    </Grid>
</Window>
