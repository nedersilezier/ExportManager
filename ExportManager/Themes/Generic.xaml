<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:ExportManager.Views">

    <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    <Style TargetType="{x:Type local:AllViewBase}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:AllViewBase}">
                    <Grid Margin="2, 0, 2, 0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="AliceBlue" Margin="0, 0, 0, 0"
                                    Visibility="{Binding IsCRUDMode, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal"  Height="30" Margin="2, 0, 0, 0">
                                    <Button Content="Add" Command="{Binding AddCommand}" Height="30" Width="70" Margin="1, 0, 1, 0"/>
                                    <Button Content="Edit" Command="{Binding EditCommand}" Height="30" Width="70" Margin="1 0, 1, 0"/>
                                    <Button Content="Remove" Command="{Binding RemoveCommand}" Height="30" Width="70" Margin="1, 0, 1, 0"/>
                                    <Button Content="Refresh" Command="{Binding LoadCommand}" Height="30" Width="70" Margin="1, 0, 6, 0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="0" Background="AliceBlue" Margin="0, 0, 0, 0"
                                    Visibility="{Binding IsSelectMode, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal"  Height="30" Margin="2, 0, 0, 0">
                                    <Button Content="Select and close" Command="{Binding SelectCommand}" Height="30" Width="Auto" Margin="1, 0, 1, 0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="DarkGray"/>
                            <ItemsControl Grid.Column="2" ItemsSource="{Binding ExtraCommands}" Margin="5, 0, 0, 0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding DisplayName}"
                                                Command="{Binding Command}"
                                                Height="30" Width="Auto" Margin="1, 0, 1, 0" Padding="5"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </Grid>
                        <Border Grid.Row="1" Background="DarkGray"/>
                        <Expander Grid.Row="2" Background="AliceBlue" Header="Filters and sorting">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition  Height="25"/>
                                    <RowDefinition  Height="25"/>
                                    <RowDefinition  Height="30"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition  Width="230"/>
                                    <ColumnDefinition  Width="60"/>
                                    <ColumnDefinition  Width="230"/>
                                </Grid.ColumnDefinitions>
                                <Label  Grid.Row="0"  Grid.Column="0" Content="Sorting:  "/>
                                <ComboBox  Grid.Row="1"  Grid.Column="0" ItemsSource="{Binding  SortComboBoxItems}"  SelectedValue="{Binding Path=SortField}"  Margin="0,0,60,0"/>
                                <Button  Content="Sort"  Grid.Row="1"  Grid.Column="0" Command="{Binding  SortCommand}" Margin="170,0,0,0"/>
                                <Label  Grid.Row="0"  Grid.Column="2" Content="Searching:  "/>
                                <ComboBox  Grid.Row="1"  Grid.Column="2" ItemsSource="{Binding  FindComboBoxItems}"  SelectedValue="{Binding Path=FindField}"  />
                                <TextBox  Grid.Row="2"  Grid.Column="2" Margin="0,5,60,0"  Text="{Binding  FindTextBox}"/>
                                <Button  Content="Search"  Grid.Row="3"  Grid.Column="2" Command="{Binding  FindCommand}" Margin="170,5,0,0"/>
                            </Grid>
                        </Expander>
                        <Border Grid.Row="3" Background="DarkGray"/>
                        <ContentPresenter Grid.Row="4" Margin="0, 5, 0, 5" ScrollViewer.HorizontalScrollBarVisibility="Visible"/>
                    </Grid>
                    <!--<Grid Margin="0, 10, 0, 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="200"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Vertical" Margin="5">
                                <StackPanel Orientation="Horizontal" Margin="5, 10, 5, 10">
                                    <Button Content="Add" Width="70" Margin="0,2"/>
                                    <Button Content="Edit" Width="70" Margin="0,2"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Remove" Width="70" Margin="0,2"/>
                                    <Button Content="Refresh" Width="70" Margin="0,2"/>
                                </StackPanel>
                            </StackPanel>
                            <Expander Grid.Row="1" Background="Azure" Header="Sortowanie i filtrowanie">
                                <Label>Tu bedzie filtrowanie i sortowanie</Label>
                            </Expander>
                        </Grid>
                        <Border Grid.Column="1" Background="DarkGray"/>
                        <Grid Grid.Column="2" Margin="0, 10, 0, 10">
                            <ContentPresenter Grid.Row="2" Margin="0, 5, 0, 5"/>
                        </Grid>
                        
                    </Grid>-->
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="{x:Type local:NewItemViewBase}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:NewItemViewBase}">
                    <Grid Margin="0, 10, 0, 0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="2, 2, 0, 2" Orientation="Horizontal" Background="AliceBlue">
                            <Button Content="Save and close" Command="{Binding SaveAndCloseCommand}" Margin="2, 0, 2, 0" Padding="5" Height="30"/>
                            <Button Content="Cancel" Command="{Binding CloseCommand}" Margin="2, 0, 2, 0" Padding="5" Height="30"/>
                        </StackPanel>
                        <!--<ToolBar Grid.Row="0" Height="30" Margin="0, 2, 0, 2">
                            <ToggleButton Content="Save and close" Command="{Binding SaveAndCloseCommand}"/>
                            <ToggleButton Content="Cancel"/>
                        </ToolBar>-->
                        <ContentPresenter Grid.Row="1" Margin="0, 5, 0, 5"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
